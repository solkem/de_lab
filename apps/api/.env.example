LAKEFORGE_APP_NAME=LakeForge Control Plane
LAKEFORGE_APP_ENV=development
LAKEFORGE_DEBUG=true
LAKEFORGE_DATABASE_URL=postgresql+psycopg://lakeforge:lakeforge@localhost:5432/lakeforge
LAKEFORGE_MINIO_ENDPOINT=localhost:9000
LAKEFORGE_MINIO_ACCESS_KEY=minioadmin
LAKEFORGE_MINIO_SECRET_KEY=minioadmin
LAKEFORGE_MINIO_BUCKET=lakeforge
LAKEFORGE_MINIO_SECURE=false
LAKEFORGE_SPARK_APP_NAME=LakeForge Spark
LAKEFORGE_SPARK_MASTER_URL=spark://localhost:7077
LAKEFORGE_SPARK_WAREHOUSE_DIR=s3a://lakeforge/managed/
LAKEFORGE_SPARK_EVENT_LOG_DIR=file:/tmp/spark-events
LAKEFORGE_AWS_ACCESS_KEY_ID=minioadmin
LAKEFORGE_AWS_SECRET_ACCESS_KEY=minioadmin
LAKEFORGE_S3_ENDPOINT_URL=http://localhost:9000
